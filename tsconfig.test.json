{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "types": ["vite/client", "vitest/globals", "node"],
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "src/__tests__/*",
    "src/**/__tests__/*",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "exclude": []
}
